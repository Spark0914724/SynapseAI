# ─── App ───────────────────────────────────────────────────────────────────────
APP_NAME=SynapseAI
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapseai
SYNC_DATABASE_URL=postgresql+asyncpg://synapse:synapse@localhost:5432/synapseai

# ─── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─── JWT ───────────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# ─── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_DEFAULT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_FREE_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_TEAM_PRICE_ID=price_...

# ─── AWS S3 / File Storage ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
S3_BUCKET_NAME=synapseai-uploads

# ─── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASSWORD=your-app-password
EMAILS_FROM_NAME=SynapseAI
EMAILS_FROM_EMAIL=noreply@synapseai.com

# ─── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60

# ─── Token Quotas ──────────────────────────────────────────────────────────────
FREE_PLAN_TOKENS=50000
PRO_PLAN_TOKENS=500000
TEAM_PLAN_TOKENS=2000000
